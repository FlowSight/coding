    {
      "id": "l63_2R-Mcc2QskBjY0XxC",
      "type": "text",
      "x": 826.8734046031109,
      "y": 410.9215621379089,
      "width": 395.53564453125,
      "height": 260,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,

      "seed": 1223497441,
      "version": 535,
      "versionNonce": 1311479841,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1778004804891,
      "link": null,
      "locked": false,
      "text": "1. how this msg is sent? \n    http call to mcs, cross origin, \n    header : s2s token of intellig service, expiry time\n    body : we can choose context size, \n        we did : trim till 5kb/session, \n            last 5 conversations of the trailing part of the window were \n            downsampled, 5:1 keyword\n    intellig control does:\n        round robin acc mcs endpoints\n        handle RAI checks\n        throttling\n        batching",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "1. how this msg is sent? \n    http call to mcs, cross origin, \n    header : s2s token of intellig service, expiry time\n    body : we can choose context size, \n        we did : trim till 5kb/session, \n            last 5 conversations of the trailing part of the window were \n            downsampled, 5:1 keyword\n    intellig control does:\n        round robin acc mcs endpoints\n        handle RAI checks\n        throttling\n        batching",
      "autoResize": true,
      "lineHeight": 1.25
    },

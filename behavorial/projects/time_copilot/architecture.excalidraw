    {
      "id": "uGgEFpwQQKjLhJXt68sCd",
      "type": "text",
      "x": 11.36505344247297,
      "y": 1013.6999515821967,
      "width": 557.3594970703125,
      "height": 240,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",

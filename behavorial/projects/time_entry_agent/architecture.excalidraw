    {
      "id": "EIsx9i9gpkoHP4MdIsQkH",
      "type": "text",
      "x": 2803.0076510982954,
      "y": 445.3985270853261,
      "width": 475.5355224609375,
      "height": 220,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],

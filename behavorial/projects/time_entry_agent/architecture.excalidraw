    {
      "id": "Si90v4gmsneCcddHIwzd1",
      "type": "text",
      "x": 427.3328199720386,
      "y": 378.7031279373169,
      "width": 532.62353515625,
      "height": 220,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "aE",
      "roundness": null,
      "seed": 1465743066,
      "version": 590,
      "versionNonce": 322868294,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1777659810167,
      "link": null,
      "locked": false,
      "text": "1. power auto mate flow auto runs every start of week day\n2. fetches all user, iterates over users, per user does below:\n3. triggers MCS(RAG) with start and end date of week\n4. rag has steps defined : \n    a. get resource assignment\n    b. ger resource booking\n    c. get existing time entries\n    d. calc intersection of (A+B) and C\n    e. get team meeting and mail info from M365 for the date range \n    f. creates comment per time entry by making a generative AI call\n    e. create time entries ",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "1. power auto mate flow auto runs every start of week day\n2. fetches all user, iterates over users, per user does below:\n3. triggers MCS(RAG) with start and end date of week\n4. rag has steps defined : \n    a. get resource assignment\n    b. ger resource booking\n    c. get existing time entries\n    d. calc intersection of (A+B) and C\n    e. get team meeting and mail info from M365 for the date range \n    f. creates comment per time entry by making a generative AI call\n    e. create time entries ",
      "autoResize": true,
      "lineHeight": 1.25
    },
